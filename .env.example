# AI-Penetration-Platform 环境变量配置文件
# 作者: 老公 (赵志强)
# 日期: 2026-07-16

# =============================================
# 应用配置
# =============================================
APP_NAME=AI-Penetration-Platform
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# =============================================
# 数据库配置
# =============================================
# PostgreSQL 数据库
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_penetration_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password-here

# MongoDB 数据库
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=ai_penetration_platform
MONGODB_USER=admin
MONGODB_PASSWORD=your-password-here

# Redis 缓存
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-password-here

# =============================================
# AI 服务配置
# =============================================
# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# TensorFlow/PyTorch 配置
TF_CPP_MIN_LOG_LEVEL=1
TORCH_HOME=./models/torch
TRANSFORMERS_CACHE=./models/transformers

# =============================================
# 扫描配置
# =============================================
# 扫描超时时间（秒）
SCAN_TIMEOUT=3600
MAX_CONCURRENT_SCANS=10
SCAN_BATCH_SIZE=100

# 网络配置
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=1

# =============================================
# 文件存储配置
# =============================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=100MB
ALLOWED_EXTENSIONS=pdf,doc,docx,txt,html,htm,json,xml

# 报告存储
REPORT_DIR=./reports
REPORT_TEMPLATE_DIR=./templates/reports

# =============================================
# 安全配置
# =============================================
# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE=30min
JWT_REFRESH_TOKEN_EXPIRE=7days

# 安全设置
BCRYPT_ROUNDS=12
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================
# 日志配置
# =============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# =============================================
# 邮件配置
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_USE_TLS=True

# =============================================
# 监控配置
# =============================================
# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics

# 健康检查
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30

# =============================================
# 第三方服务配置
# =============================================
# GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Discord
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# Slack
SLACK_WEBHOOK_URL=your-slack-webhook-url

# =============================================
# 开发配置
# =============================================
# 开发模式
DEV_MODE=True
DEV_DATABASE_URL=sqlite:///./dev.db

# 测试配置
TEST_DATABASE_URL=sqlite:///./test.db
TEST_MODE=False

# =============================================
# 生产环境配置
# =============================================
# 生产模式
PRODUCTION_MODE=False
PROXY_URL=http://localhost:8080

# SSL 配置
SSL_CERT_FILE=./certs/cert.pem
SSL_KEY_FILE=./certs/key.pem